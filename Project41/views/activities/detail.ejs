<% pageTitle = activity.title; activeNav = 'activities'; %>
<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <a href="/activities" class="text-decoration-none text-muted small">
      <i class="bi bi-arrow-left"></i> 返回活动列表
    </a>
    <h3 class="mb-0 mt-1"><%= activity.title %></h3>
  </div>
  <% if (activity.status !== 'completed') { %>
  <div class="d-flex gap-2">
    <a href="/activities/<%= activity.id %>/edit" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-pencil"></i> 编辑
    </a>
    <button onclick="confirmDelete('/activities/<%= activity.id %>', '确定要删除这个活动吗？')" class="btn btn-outline-danger btn-sm">
      <i class="bi bi-trash"></i> 删除
    </button>
  </div>
  <% } %>
</div>

<% var isFull = activity.registered_count >= activity.max_participants; %>
<% var fillRate = Math.round(activity.registered_count / activity.max_participants * 100); %>
<% var statusClass = activity.status === 'upcoming' ? 'bg-info' : activity.status === 'ongoing' ? 'bg-warning' : 'bg-secondary'; %>
<% var statusText = activity.status === 'upcoming' ? '即将开始' : activity.status === 'ongoing' ? '进行中' : '已结束'; %>
<% var headerClass = activity.status === 'upcoming' ? 'bg-info bg-opacity-10' : activity.status === 'ongoing' ? 'bg-warning bg-opacity-10' : 'bg-secondary bg-opacity-10'; %>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span class="category-tag"><%= activity.category %></span>
          <span class="badge <%= statusClass %>"><%= statusText %></span>
        </div>
        <p class="text-muted mb-4"><%= activity.description || '暂无活动描述' %></p>
        <div class="row g-3">
          <div class="col-6">
            <div class="activity-meta">
              <i class="bi bi-geo-alt"></i> 活动地点
            </div>
            <div class="fw-semibold"><%= activity.location %></div>
          </div>
          <div class="col-6">
            <div class="activity-meta">
              <i class="bi bi-calendar3"></i> 活动日期
            </div>
            <div class="fw-semibold"><%= activity.activity_date %></div>
          </div>
          <div class="col-6">
            <div class="activity-meta">
              <i class="bi bi-clock"></i> 活动时间
            </div>
            <div class="fw-semibold"><%= activity.start_time %> - <%= activity.end_time %></div>
          </div>
          <div class="col-6">
            <div class="activity-meta">
              <i class="bi bi-person-plus"></i> 报名人数
            </div>
            <div class="fw-semibold"><%= activity.registered_count %> / <%= activity.max_participants %> 人</div>
          </div>
        </div>
        <div class="mt-4">
          <div class="d-flex justify-content-between small mb-1">
            <span class="text-muted">报名进度</span>
            <span class="<%= isFull ? 'text-danger' : 'text-success' %>"><%= fillRate %>%</span>
          </div>
          <div class="progress" style="height: 10px;">
            <div class="progress-bar <%= isFull ? 'bg-danger' : 'bg-success' %>" style="width: <%= fillRate %>%"></div>
          </div>
        </div>
      </div>
    </div>

    <% if (activity.status !== 'completed') { %>
    <div class="card shadow-sm">
      <div class="card-header bg-primary bg-opacity-10">
        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> 在线报名</h5>
      </div>
      <div class="card-body">
        <% if (activity.registered_count >= activity.max_participants) { %>
        <div class="alert alert-warning mb-0">
          <i class="bi bi-exclamation-triangle"></i> 该活动报名人数已满，无法继续报名。
        </div>
        <% } else { %>
        <form method="POST" action="/activities/<%= activity.id %>/register">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">姓名 <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control <%= typeof registerErrors !== 'undefined' && registerErrors.name ? 'is-invalid' : '' %>" value="<%= typeof registerData !== 'undefined' ? registerData.name : '' %>" required>
              <% if (typeof registerErrors !== 'undefined' && registerErrors.name) { %>
              <div class="invalid-feedback"><%= registerErrors.name %></div>
              <% } %>
            </div>
            <div class="col-md-6">
              <label class="form-label">性别</label>
              <select name="gender" class="form-select">
                <option value="male" <%= typeof registerData !== 'undefined' && registerData.gender === 'male' ? 'selected' : '' %>>男</option>
                <option value="female" <%= typeof registerData !== 'undefined' && registerData.gender === 'female' ? 'selected' : '' %>>女</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">年龄</label>
              <input type="number" name="age" class="form-control" min="50" max="120" value="<%= typeof registerData !== 'undefined' ? registerData.age : '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">联系电话 <span class="text-danger">*</span></label>
              <input type="tel" name="phone" class="form-control <%= typeof registerErrors !== 'undefined' && registerErrors.phone ? 'is-invalid' : '' %>" value="<%= typeof registerData !== 'undefined' ? registerData.phone : '' %>" required>
              <% if (typeof registerErrors !== 'undefined' && registerErrors.phone) { %>
              <div class="invalid-feedback"><%= registerErrors.phone %></div>
              <% } %>
            </div>
            <div class="col-md-6">
              <label class="form-label">身份证号</label>
              <input type="text" name="id_card" class="form-control" value="<%= typeof registerData !== 'undefined' ? registerData.id_card : '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">健康状况备注</label>
              <input type="text" name="health_note" class="form-control" placeholder="如：高血压、糖尿病等" value="<%= typeof registerData !== 'undefined' ? registerData.health_note : '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">紧急联系人</label>
              <input type="text" name="emergency_contact" class="form-control" value="<%= typeof registerData !== 'undefined' ? registerData.emergency_contact : '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">紧急联系电话</label>
              <input type="tel" name="emergency_phone" class="form-control" value="<%= typeof registerData !== 'undefined' ? registerData.emergency_phone : '' %>">
            </div>
          </div>
          <div class="mt-4">
            <button type="submit" class="btn btn-primary px-4">
              <i class="bi bi-check-lg"></i> 确认报名
            </button>
          </div>
        </form>
        <% } %>
      </div>
    </div>
    <% } %>
  </div>

  <div class="col-lg-5">
    <div class="card shadow-sm">
      <div class="card-header bg-success bg-opacity-10">
        <h5 class="mb-0"><i class="bi bi-people"></i> 报名人员 (<%= participants.length %>人)</h5>
      </div>
      <div class="card-body">
        <% if (participants.length === 0) { %>
        <div class="text-center py-4 text-muted">
          <i class="bi bi-person-x display-4"></i>
          <p class="mt-2 mb-0">暂无报名人员</p>
        </div>
        <% } else { %>
        <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
          <table class="table table-hover align-middle">
            <thead class="table-light sticky-top">
              <tr>
                <th>姓名</th>
                <th>性别</th>
                <th>年龄</th>
                <th>电话</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody>
              <% participants.forEach(function(p) { %>
              <tr>
                <td><%= p.name %></td>
                <td><%= p.gender === 'male' ? '男' : '女' %></td>
                <td><%= p.age || '-' %></td>
                <td><small><%= p.phone %></small></td>
                <td>
                  <% if (activity.status !== 'completed') { %>
                  <button onclick="confirmDelete('/activities/<%= activity.id %>/participants/<%= p.id %>', '确定要取消<%= p.name %>的报名吗？')" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                  </button>
                  <% } %>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
