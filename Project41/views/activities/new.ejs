<% pageTitle = '发布活动'; activeNav = 'activities'; %>
<%- include('../partials/header') %>

<div class="mb-4">
  <a href="/activities" class="text-decoration-none text-muted small">
    <i class="bi bi-arrow-left"></i> 返回活动列表
  </a>
  <h3 class="mb-0 mt-1"><i class="bi bi-plus-circle"></i> 发布活动</h3>
</div>

<div class="card shadow-sm">
  <div class="card-body p-4">
    <form method="POST" action="/activities">
      <div class="row g-3">
        <div class="col-12">
          <label class="form-label">活动标题 <span class="text-danger">*</span></label>
          <input type="text" name="title" class="form-control <%= errors.title ? 'is-invalid' : '' %>" value="<%= activity ? activity.title : '' %>" placeholder="例如：夕阳红合唱团排练" required>
          <% if (errors.title) { %>
          <div class="invalid-feedback"><%= errors.title %></div>
          <% } %>
        </div>
        <div class="col-12">
          <label class="form-label">活动描述</label>
          <textarea name="description" class="form-control" rows="3" placeholder="简要描述活动内容、目的等"><%= activity ? activity.description : '' %></textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">活动地点 <span class="text-danger">*</span></label>
          <input type="text" name="location" class="form-control <%= errors.location ? 'is-invalid' : '' %>" value="<%= activity ? activity.location : '' %>" placeholder="例如：社区文化活动中心" required>
          <% if (errors.location) { %>
          <div class="invalid-feedback"><%= errors.location %></div>
          <% } %>
        </div>
        <div class="col-md-6">
          <label class="form-label">活动类别</label>
          <select name="category" class="form-select">
            <option value="文娱活动">文娱活动</option>
            <option value="健身活动">健身活动</option>
            <option value="健康讲座">健康讲座</option>
            <option value="节庆活动">节庆活动</option>
            <option value="技能培训">技能培训</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">活动日期 <span class="text-danger">*</span></label>
          <input type="date" name="activity_date" class="form-control <%= errors.activity_date ? 'is-invalid' : '' %>" value="<%= activity ? activity.activity_date : '' %>" required>
          <% if (errors.activity_date) { %>
          <div class="invalid-feedback"><%= errors.activity_date %></div>
          <% } %>
        </div>
        <div class="col-md-4">
          <label class="form-label">开始时间 <span class="text-danger">*</span></label>
          <input type="time" name="start_time" class="form-control <%= errors.start_time ? 'is-invalid' : '' %>" value="<%= activity ? activity.start_time : '' %>" required>
          <% if (errors.start_time) { %>
          <div class="invalid-feedback"><%= errors.start_time %></div>
          <% } %>
        </div>
        <div class="col-md-4">
          <label class="form-label">结束时间 <span class="text-danger">*</span></label>
          <input type="time" name="end_time" class="form-control <%= errors.end_time ? 'is-invalid' : '' %>" value="<%= activity ? activity.end_time : '' %>" required>
          <% if (errors.end_time) { %>
          <div class="invalid-feedback"><%= errors.end_time %></div>
          <% } %>
        </div>
        <div class="col-md-4">
          <label class="form-label">最大参与人数</label>
          <input type="number" name="max_participants" class="form-control" min="1" max="500" value="<%= activity ? activity.max_participants : 50 %>">
        </div>
        <div class="col-12 mt-4">
          <button type="submit" class="btn btn-primary px-4">
            <i class="bi bi-check-lg"></i> 发布活动
          </button>
          <a href="/activities" class="btn btn-outline-secondary px-4">
            <i class="bi bi-x-lg"></i> 取消
          </a>
        </div>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
