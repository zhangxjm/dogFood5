<% pageTitle = '首页'; activeNav = 'home'; %>
<%- include('partials/header') %>

<div class="hero-section text-center">
  <h1><i class="bi bi-sun-fill me-2"></i>精彩晚年，乐享生活</h1>
  <p class="mb-0">为社区老年人打造的活动报名平台，丰富文娱生活，促进邻里交流</p>
</div>

<div class="row g-4 mb-5">
  <div class="col-md-3 col-6">
    <div class="card stat-card shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-primary bg-opacity-10 text-primary me-3">
            <i class="bi bi-calendar-event"></i>
          </div>
          <div>
            <div class="text-muted small">活动总数</div>
            <div class="fs-3 fw-bold"><%= stats.total_activities || 0 %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card stat-card shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-success bg-opacity-10 text-success me-3">
            <i class="bi bi-people"></i>
          </div>
          <div>
            <div class="text-muted small">参与总人次</div>
            <div class="fs-3 fw-bold"><%= stats.total_registrations || 0 %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card stat-card shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-warning bg-opacity-10 text-warning me-3">
            <i class="bi bi-hourglass-split"></i>
          </div>
          <div>
            <div class="text-muted small">进行中</div>
            <div class="fs-3 fw-bold"><%= stats.ongoing_count || 0 %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card stat-card shadow-sm">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="stat-icon bg-info bg-opacity-10 text-info me-3">
            <i class="bi bi-calendar-check"></i>
          </div>
          <div>
            <div class="text-muted small">即将开始</div>
            <div class="fs-3 fw-bold"><%= stats.upcoming_count || 0 %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="mb-0"><i class="bi bi-stars text-warning"></i> 最新活动</h3>
  <a href="/activities" class="btn btn-outline-primary btn-sm">
    查看全部 <i class="bi bi-arrow-right"></i>
  </a>
</div>

<% if (activities.length === 0) { %>
<div class="text-center py-5">
  <i class="bi bi-inbox display-1 text-muted"></i>
  <p class="text-muted mt-3">暂无活动，点击右上角发布活动</p>
</div>
<% } else { %>
<div class="row g-4">
  <% activities.slice(0, 6).forEach(function(a) { %>
    <% var isFull = a.registered_count >= a.max_participants; %>
    <% var fillRate = Math.round(a.registered_count / a.max_participants * 100); %>
    <% var statusClass = a.status === 'upcoming' ? 'bg-info' : a.status === 'ongoing' ? 'bg-warning' : 'bg-secondary'; %>
    <% var statusText = a.status === 'upcoming' ? '即将开始' : a.status === 'ongoing' ? '进行中' : '已结束'; %>
    <% var headerClass = a.status === 'upcoming' ? 'bg-info bg-opacity-10' : a.status === 'ongoing' ? 'bg-warning bg-opacity-10' : 'bg-secondary bg-opacity-10'; %>
  <div class="col-md-6 col-lg-4">
    <div class="card card-activity shadow-sm h-100">
      <div class="card-header <%= headerClass %>">
        <div class="d-flex justify-content-between align-items-center">
          <span class="category-tag"><%= a.category %></span>
          <span class="badge status-badge <%= statusClass %>"><%= statusText %></span>
        </div>
      </div>
      <div class="card-body">
        <h5 class="card-title mb-3"><%= a.title %></h5>
        <div class="activity-meta mb-2">
          <i class="bi bi-geo-alt"></i><%= a.location %>
        </div>
        <div class="activity-meta mb-2">
          <i class="bi bi-calendar3"></i><%= a.activity_date %> <%= a.start_time %>-<%= a.end_time %>
        </div>
        <div class="mb-3">
          <div class="d-flex justify-content-between small mb-1">
            <span class="text-muted">报名进度</span>
            <span class="<%= isFull ? 'text-danger' : 'text-success' %>"><%= a.registered_count %>/<%= a.max_participants %>人</span>
          </div>
          <div class="progress progress-mini">
            <div class="progress-bar <%= isFull ? 'bg-danger' : 'bg-success' %>" style="width: <%= fillRate %>%"></div>
          </div>
        </div>
        <a href="/activities/<%= a.id %>" class="btn btn-sm <%= a.status === 'completed' ? 'btn-outline-secondary' : isFull ? 'btn-outline-danger' : 'btn-primary' %> w-100">
          <%= a.status === 'completed' ? '查看详情' : isFull ? '已满员' : '立即报名' %>
        </a>
      </div>
    </div>
  </div>
  <% }); %>
</div>
<% } %>

<%- include('partials/footer') %>
