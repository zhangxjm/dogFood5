  </div>

  <footer class="footer mt-auto">
    <div class="container text-center text-muted">
      <p class="mb-0">&copy; <%= currentYear %> 社区老年活动报名系统 · 关爱老人，丰富生活</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('success') === 'registered') {
        showAlert('报名成功！我们期待您的参与！', 'success');
      }
      if (urlParams.get('error') === 'full') {
        showAlert('抱歉，该活动报名人数已满！', 'danger');
      }
    });

    function showAlert(message, type) {
      const container = document.querySelector('.main-content');
      const alert = document.createElement('div');
      alert.className = 'alert alert-' + type + ' alert-flash alert-dismissible fade show';
      alert.innerHTML = message + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
      container.insertBefore(alert, container.firstChild);
    }

    function confirmDelete(url, message) {
      if (confirm(message || '确定要删除吗？')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = url;
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = '_method';
        input.value = 'DELETE';
        form.appendChild(input);
        document.body.appendChild(form);
        form.submit();
      }
    }
  </script>
</body>
</html>
