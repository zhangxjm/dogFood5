<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' : '' %>社区老年活动报名系统</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body {
      background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .navbar-brand {
      font-weight: 700;
      font-size: 1.4rem;
    }
    .navbar-brand i {
      color: #ff6b35;
    }
    .main-content {
      padding-top: 2rem;
      padding-bottom: 3rem;
      flex: 1;
    }
    .card-activity {
      transition: transform 0.2s, box-shadow 0.2s;
      border: none;
      border-radius: 12px;
      overflow: hidden;
    }
    .card-activity:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px rgba(0,0,0,0.12);
    }
    .card-activity .card-header {
      border: none;
      padding: 1rem 1.25rem;
    }
    .status-badge {
      font-size: 0.85rem;
      padding: 0.3em 0.7em;
    }
    .stat-card {
      border: none;
      border-radius: 12px;
      transition: transform 0.2s;
    }
    .stat-card:hover {
      transform: translateY(-2px);
    }
    .stat-card .card-body {
      padding: 1.5rem;
    }
    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
    }
    .activity-meta {
      font-size: 0.9rem;
      color: #6c757d;
    }
    .activity-meta i {
      width: 18px;
      margin-right: 4px;
    }
    .progress-mini {
      height: 6px;
      border-radius: 3px;
    }
    .table thead th {
      border-bottom-width: 2px;
      font-weight: 600;
    }
    .btn-action {
      padding: 0.25rem 0.5rem;
      font-size: 0.875rem;
    }
    .category-tag {
      display: inline-block;
      padding: 0.25em 0.6em;
      font-size: 0.8rem;
      border-radius: 4px;
      background: #e7f5ff;
      color: #1971c2;
    }
    .hero-section {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      border-radius: 16px;
      padding: 3rem 2rem;
      color: white;
      margin-bottom: 2rem;
    }
    .hero-section h1 {
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .hero-section p {
      font-size: 1.1rem;
      opacity: 0.95;
    }
    .form-label {
      font-weight: 500;
    }
    .footer {
      background: #fff;
      border-top: 1px solid #dee2e6;
      padding: 1.5rem 0;
      margin-top: auto;
    }
    .alert-flash {
      border-radius: 10px;
    }
    .participant-card {
      border: 1px solid #e9ecef;
      border-radius: 10px;
      padding: 1rem;
      margin-bottom: 0.75rem;
      background: #f8f9fa;
    }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container">
      <a class="navbar-brand" href="/">
        <i class="bi bi-heart-pulse-fill"></i> 社区老年活动报名系统
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link <%= activeNav === 'home' ? 'active' : '' %>" href="/">
              <i class="bi bi-house-door"></i> 首页
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= activeNav === 'activities' ? 'active' : '' %>" href="/activities">
              <i class="bi bi-calendar-event"></i> 活动列表
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= activeNav === 'participants' ? 'active' : '' %>" href="/participants">
              <i class="bi bi-people"></i> 报名人员
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= activeNav === 'statistics' ? 'active' : '' %>" href="/statistics">
              <i class="bi bi-bar-chart"></i> 统计分析
            </a>
          </li>
        </ul>
        <a href="/activities/new" class="btn btn-warning btn-sm">
          <i class="bi bi-plus-circle"></i> 发布活动
        </a>
      </div>
    </div>
  </nav>

  <div class="container main-content">
